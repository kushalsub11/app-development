@page "/journal"
@using Week8.Models
@inject NavigationManager Navigation


<h3>Journal Entry</h3>

@if (!pinVerified)
{
    <EditForm Model="this" OnValidSubmit="VerifyPin">
        <label>Enter PIN to access your journal:</label><br />
        <InputText @bind-Value="pinInput" type="password" />
        <button type="submit">Unlock</button>
        @if (pinError != null)
        {
            <div style="color:red">@pinError</div>
        }
    </EditForm>
}
else if (entry == null)
{
    <EditForm Model="newEntry" OnValidSubmit="CreateEntry">
        <InputTextArea @bind-Value="newEntry.Content" placeholder="Write your journal entry..." />
        <br />
        <label>Primary Mood (required):</label>
        <InputSelect @bind-Value="newEntry.PrimaryMood">
            <option value="">Select mood</option>
            @foreach (var mood in PrimaryMoods)
            {
                <option value="@mood">@mood</option>
            }
        </InputSelect>
        <br />
        <label>Secondary Mood 1 (optional):</label>
        <InputSelect @bind-Value="newEntry.SecondaryMood1">
            <option value="">None</option>
            @foreach (var mood in AllMoods)
            {
                <option value="@mood">@mood</option>
            }
        </InputSelect>
        <br />
        <label>Secondary Mood 2 (optional):</label>
        <InputSelect @bind-Value="newEntry.SecondaryMood2">
            <option value="">None</option>
            @foreach (var mood in AllMoods)
            {
                <option value="@mood">@mood</option>
            }
        </InputSelect>
        <br />
        <button type="submit">Save Entry</button>
    </EditForm>
}
else
{
    <div>
        <b>Date:</b> @entry.Date.ToShortDateString()<br />
        <b>Content:</b> @entry.Content<br />
        <b>Primary Mood:</b> @entry.PrimaryMood<br />
        <b>Secondary Moods:</b> @entry.SecondaryMood1, @entry.SecondaryMood2<br />
        <button @onclick="EditEntry">Edit</button>
        <button @onclick="DeleteEntry">Delete</button>
    </div>
}

@code {
    private JournalEntry? entry;
    private JournalEntry newEntry = new();

    // PIN logic
    private string pinInput = string.Empty;
    private bool pinVerified = false;
    private string? pinError = null;
    private const string correctPin = "1234"; // Change this to your desired PIN

    private void VerifyPin()
    {
        if (pinInput == correctPin)
        {
            pinVerified = true;
            pinError = null;
        }
        else
        {
            pinError = "Incorrect PIN. Try again.";
        }
    }

    private static readonly string[] PositiveMoods = { "Happy", "Excited", "Relaxed", "Grateful", "Confident" };
    private static readonly string[] NeutralMoods = { "Calm", "Thoughtful", "Curious", "Nostalgic", "Bored" };
    private static readonly string[] NegativeMoods = { "Sad", "Angry", "Stressed", "Lonely", "Anxio" };
    private static readonly string[] PrimaryMoods = PositiveMoods.Concat(NeutralMoods).Concat(NegativeMoods).ToArray();
    private static readonly string[] AllMoods = PrimaryMoods;

    protected override void OnInitialized()
    {
        // For demo: load today's entry from local storage/service (not implemented)
        // entry = ...
    }

    private void CreateEntry()
    {
        newEntry.Date = DateTime.Today;
        entry = newEntry;
        newEntry = new();
    }

    private void EditEntry()
    {
        newEntry = entry!;
        entry = null;
    }

    private void DeleteEntry()
    {
        entry = null;
    }
}
